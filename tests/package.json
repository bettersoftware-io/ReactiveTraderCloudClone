{
  "name": "@rtc/tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf .turbo reports 2>/dev/null || true",
    "clean:deep": "pnpm run clean && (rm -rf node_modules 2>/dev/null || true)",
    "gates": "tsx scripts/grep-gates.ts",
    "port:free": "tsx scripts/free-port.ts",
    "test:browser:cypress": "tsx scripts/with-server.ts cypress run --headless --config-file browser/cypress/cypress.config.ts",
    "test:browser:cypress:headed": "tsx scripts/with-server.ts cypress open --e2e --config-file browser/cypress/cypress.config.ts",
    "test:browser:cypress-cucumber": "CYPRESS_TAGS='not @presenterOnly' tsx scripts/with-server.ts cypress run --headless --config-file browser/cypress-cucumber/cypress.config.ts",
    "test:browser:cypress-cucumber:headed": "CYPRESS_TAGS='not @presenterOnly' tsx scripts/with-server.ts cypress open --e2e --config-file browser/cypress-cucumber/cypress.config.ts",
    "test:browser:playwright": "tsx scripts/with-server.ts playwright test --config browser/playwright/playwright.config.ts",
    "test:browser:playwright:headed": "tsx scripts/with-server.ts playwright test --headed --config browser/playwright/playwright.config.ts",
    "test:browser:playwright:ui": "tsx scripts/with-server.ts playwright test --ui --config browser/playwright/playwright.config.ts",
    "test:browser:playwright-cucumber": "NODE_OPTIONS='--import tsx/esm' tsx scripts/with-server.ts cucumber-js --config browser/playwright-cucumber/cucumber.js",
    "test:browser:playwright-cucumber:headed": "PWCUCUMBER_HEADED=1 NODE_OPTIONS='--import tsx/esm' tsx scripts/with-server.ts cucumber-js --config browser/playwright-cucumber/cucumber.js",
    "test:e2e": "pnpm gates && tsx scripts/run-all.ts",
    "test:fullstack:browser": "tsx fullstack/browser-smoke.ts",
    "test:fullstack:browser:headed": "FULLSTACK_HEADED=1 tsx fullstack/browser-smoke.ts",
    "test:fullstack:node": "tsx fullstack/node-smoke.ts",
    "test:presenter:cucumber": "NODE_OPTIONS='--import tsx/esm' cucumber-js --config presenter/cucumber/cucumber.js",
    "test:presenter:cucumber-fake-timers": "NODE_OPTIONS='--import tsx/esm' cucumber-js --config presenter/cucumber-fake-timers/cucumber.js",
    "test:presenter:vitest-fake-timers": "vitest run --config presenter/vitest-fake-timers/vitest.config.ts",
    "test:presenter:vitest-quickpickle-fake-timers": "vitest run --config presenter/vitest-quickpickle-fake-timers/vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rtc/client": "workspace:*",
    "@rtc/domain": "workspace:*",
    "@rtc/server": "workspace:*",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.60.0",
    "@sinonjs/fake-timers": "^15.0.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.1.8",
    "cypress": "15.16.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "0.28.1",
    "quickpickle": "^1.11",
    "tsx": "^4.19.0",
    "typescript": "^6",
    "vitest": "^4"
  }
}
