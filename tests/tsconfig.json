{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["node", "cypress"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "browser/**/*.ts",
    "browser/playwright-cucumber/cucumber.js",
    "steps/**/*.ts",
    "support/**/*.ts",
    "fullstack/**/*.ts",
    "scripts/**/*.ts"
  ]
}
