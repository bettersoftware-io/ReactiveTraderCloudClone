{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".remember/**", "docs/design/**"],
  "ignoreBinaries": ["scripts/install-actionlint.sh"],
  "workspaces": {
    "packages/domain": {
      "entry": ["src/index.ts", "src/ports/__contracts__/*.ts"],
      "project": "src/**/*.ts"
    },
    "packages/shared": {
      "entry": ["src/index.ts", "src/__fixtures__/wireFrames.ts"],
      "project": "src/**/*.ts"
    },
    "packages/ws-effects": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/devtools-core": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/devtools-app": {
      "entry": ["src/main.tsx", "index.html", "vite.config.ts"],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/devtools-relay": {
      "entry": ["src/index.ts", "src/bin.ts"],
      "project": "src/**/*.ts"
    },
    "packages/devtools-extension": {
      "entry": [
        "src/background.ts",
        "src/contentBridge.ts",
        "src/devtools.ts",
        "src/panel/panel.tsx",
        "vite.config.ts"
      ],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/motion-core": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/boot-splash": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/solid-bindings": {
      "entry": "src/index.ts",
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/client-solid": {
      "entry": [
        "src/main.tsx",
        "index.html",
        "vite.config.ts",
        "tests/ui/visual/playwright/host/main.tsx",
        "tests/ui/visual/playwright/host/vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@rtc/ui-contract"]
    },
    "packages/ui-contract": {
      "entry": [
        "src/shared/components.ts",
        "src/shared/mount.ts",
        "src/specs/**/*.contract.spec.ts",
        "src/visual/scenarios.test.ts",
        "src/visual/fixtures.ts",
        "src/visual/freezeClock.ts",
        "src/visual/scenarioActions.ts"
      ],
      "project": "src/**/*.ts"
    },
    "packages/server": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "packages/client-react": {
      "entry": [
        "src/main.tsx",
        "src/index.ts",
        "index.html",
        "vite.config.ts",
        "tests/ui/visual/playwright/host/main.tsx",
        "tests/ui/visual/playwright/host/vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@rtc/ui-contract"]
    },
    "packages/client-react-native": {
      "entry": [
        "app/**/*.{ts,tsx}",
        "app.config.ts",
        "metro.config.js",
        "babel.config.js",
        "vitest.config.ts",
        "jest.config.js",
        "jest.setup.ts",
        "jest.resolver.js",
        "expo-env.d.ts",
        "scripts/liveWsSmoke.ts",
        "tests/visual/driver.ts",
        "tests/visual/maestro/generateFlows.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "expo-status-bar",
        "babel-plugin-module-resolver",
        "babel-preset-expo",
        "expo-blur",
        "expo-haptics",
        "expo-sensors"
      ]
    },
    "tests": {
      "entry": [
        "**/*.spec.{ts,tsx}",
        "**/*.steps.ts",
        "scripts/*.ts",
        "**/*.config.{ts,js}",
        "browser/playwright-cucumber/hooks.ts",
        "browser/playwright-cucumber/world.ts",
        "presenter/cucumber-fake-timers/hooks.ts",
        "presenter/cucumber-fake-timers/world.ts"
      ],
      "project": "**/*.{ts,tsx}",
      "ignoreDependencies": ["@rtc/server"]
    }
  }
}
