node_modules/
dist/
.turbo/
*.tsbuildinfo
reports/
playwright-report/
test-results/
.pnpm-store/
.idea/
# macOS Finder metadata (can appear in any directory)
.DS_Store
.github/.token

# Claude Code: per-machine settings (paths, machine-specific allow-listings)
.claude/settings.local.json
# Claude Code: runtime scheduled-task lock (not a project file)
.claude/scheduled_tasks.lock

# Visual test screenshots: only the curated golden sets under react/ (CI x86)
# and react-local/<arch>/ (local feedback) are committed. The Playwright /
# vitest-browser runners also drop transient debris into a spec-named dir
# DIRECTLY under __screenshots__/ (e.g. __screenshots__/visual.spec.tsx/
# app-credit-1.png) — never a golden, must never be committed. Real goldens
# always have react/ or react-local/<arch>/ between __screenshots__ and the spec
# dir, so this can't match them. The goldens themselves live under
# packages/ui-contract/goldens/ (generated exclusively from client-react's
# renders) — this same debris-dir shape can appear there too.
packages/*/tests/ui/visual/**/__screenshots__/*.spec.ts/
packages/*/tests/ui/visual/**/__screenshots__/*.spec.tsx/
packages/ui-contract/goldens/**/__screenshots__/*.spec.ts/
packages/ui-contract/goldens/**/__screenshots__/*.spec.tsx/

# actionlint binary (downloaded via scripts/install-actionlint.sh)
.tooling/

# Vercel CLI local project config (written by `vercel link` / `vercel pull`)
.vercel/

# Subagent-driven-development scratch (ledger, task briefs, review packages, reports)
.superpowers/

# Local env files (Expo EXPO_PUBLIC_* and friends) — may hold tokens, never
# commit them. `.env.example` templates ARE tracked (not matched below).
.env
.env.local
.env.*.local
.playwright-mcp/

# Temp dir used by scripts/goldens-in-container.mjs to shuttle container-rendered
# goldens back into the working tree; never committed.
.golden-out/
