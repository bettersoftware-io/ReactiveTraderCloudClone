# Copy this file to `.env` (same directory) and fill in the values you need.
# `.env` is git-ignored — never commit a real token.
#
# EXPO_PUBLIC_* variables are read by Expo and INLINED into the app bundle,
# so treat them as visible, not secret (soft gate for demos only).
# See this package's README ("Signing in").

# Simulator-mode (`Sim` toggle) dev credentials only — a JSON `username ->
# password` object, mirroring client-react's `VITE_DEV_AUTH`. Unset (or
# empty/malformed) falls back to all four roster usernames at the shared
# committed demo password ("mcdc2026"), so the offline simulator still boots
# into a working login with no env set at all. Never used against a real
# deployed server — live mode signs in with any credential from the server's
# `AUTH_USERS` secret (ask the team for real deployed credentials); no creds
# are baked for that branch.
# EXPO_PUBLIC_DEV_AUTH={"astark":"mcdc2026","demo":"mcdc2026"}
EXPO_PUBLIC_DEV_AUTH=

# Optional — overrides the WebSocket endpoint. Defaults to the deployed Fly
# server when unset, so you normally do not need this.
# EXPO_PUBLIC_SERVER_URL=wss://rtc-clone-server.fly.dev
