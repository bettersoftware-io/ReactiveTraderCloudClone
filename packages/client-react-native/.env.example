# Copy this file to `.env` (same directory) and fill in the values you need.
# `.env` is git-ignored — never commit a real token.
#
# EXPO_PUBLIC_* variables are read by Expo and INLINED into the app bundle,
# so treat them as visible, not secret (soft gate for demos only).
# See this package's README ("Auto-login & the demo credential").

# The baked demo credential the app auto-logs-in with on every launch (RN has
# no login UI yet). Both default to the public "demo" roster account when
# unset, so the app boots authenticated with no env set at all. Against a real
# deployed server, this pair must exist in its `AUTH_USERS` secret — ask the
# team for real deployed credentials.
EXPO_PUBLIC_DEMO_USER=
EXPO_PUBLIC_DEMO_PASS=

# Optional — overrides the WebSocket endpoint. Defaults to the deployed Fly
# server when unset, so you normally do not need this.
# EXPO_PUBLIC_SERVER_URL=wss://rtc-clone-server.fly.dev
