{
  "name": "@rtc/client-react-native",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "imports": {
    "#/*": "./src/*"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests && jest",
    "build": "tsc --noEmit",
    "export": "expo export --platform ios --output-dir dist",
    "smoke:ws": "tsx scripts/liveWsSmoke.ts",
    "test:rn:visual:simctl": "tsx tests/visual/simctl/run.ts",
    "test:rn:visual:simctl:update": "tsx tests/visual/simctl/run.ts --update",
    "test:rn:visual:maestro": "tsx tests/visual/maestro/run.ts",
    "test:rn:visual:maestro:update": "tsx tests/visual/maestro/run.ts --update",
    "test:rn:visual:owl": "owl build --platform ios && owl test --platform ios",
    "test:rn:visual:owl:update": "owl test --platform ios --update",
    "clean": "rm -rf dist .turbo .expo *.tsbuildinfo node_modules/.cache 2>/dev/null || true",
    "clean:deep": "pnpm run clean && (rm -rf node_modules ios android 2>/dev/null || true)"
  },
  "dependencies": {
    "@expo-google-fonts/chakra-petch": "^0.4.1",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/orbitron": "^0.4.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@rtc/client-core": "workspace:*",
    "@rtc/devtools-core": "workspace:*",
    "@rtc/domain": "workspace:*",
    "@rtc/motion-core": "workspace:*",
    "@rtc/react-bindings": "workspace:*",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "^57.0.0",
    "expo-blur": "~57.0.2",
    "expo-constants": "^57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.1",
    "expo-linking": "~57.0.1",
    "expo-router": "^57.0.3",
    "expo-sensors": "~57.0.2",
    "expo-status-bar": "^57.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.23.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@rtc/devtools-relay": "workspace:*",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~57.0.1",
    "jest": "^30.0.0",
    "jest-expo": "^57.0.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "react-native-owl": "^1.5.0",
    "test-renderer": "^1.2.0",
    "tsx": "^4",
    "typescript": "^6",
    "vitest": "^4"
  }
}
