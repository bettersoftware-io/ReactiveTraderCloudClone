{
  "name": "@rtc/client-react-native",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "expo start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests && jest",
    "build": "tsc --noEmit",
    "export": "expo export --platform ios --output-dir dist",
    "smoke:ws": "tsx scripts/liveWsSmoke.ts",
    "clean": "rm -rf dist .turbo .expo *.tsbuildinfo node_modules/.cache 2>/dev/null || true",
    "clean:deep": "pnpm run clean && (rm -rf node_modules 2>/dev/null || true)"
  },
  "dependencies": {
    "@expo-google-fonts/chakra-petch": "^0.4.1",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@rtc/client-core": "workspace:*",
    "@rtc/domain": "workspace:*",
    "@rtc/react-bindings": "workspace:*",
    "expo": "^55.0.0",
    "expo-constants": "^55.0.16",
    "expo-font": "~55.0.8",
    "expo-router": "^55.0.16",
    "expo-status-bar": "^55.0.6",
    "react": "^19",
    "react-dom": "^19",
    "react-native": "^0.83.6",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-svg": "15.15.3",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.19",
    "test-renderer": "^1.2.0",
    "tsx": "^4",
    "typescript": "^6",
    "vitest": "^4"
  }
}
