{
  "name": "@rtc/client-solid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.ui-contract.json && tsc --noEmit -p tsconfig.ui-visual.json",
    "test": "vitest run",
    "test:ui:contract": "vitest run -c tests/ui/contract/vitest.config.ts",
    "test:ui:contract:coverage": "vitest run -c tests/ui/contract/vitest.coverage.config.ts --coverage",
    "test:ui:visual": "tsx tests/ui/visual/run-all.ts",
    "test:ui:visual:solid": "tsx tests/ui/visual/run-all.ts solid",
    "test:ui:visual:playwright:solid": "playwright test -c tests/ui/visual/playwright/playwright.config.ts",
    "test:ui:visual:playwright:solid:ui": "playwright test -c tests/ui/visual/playwright/playwright.config.ts --ui",
    "dev": "vite",
    "clean": "(rm -rf dist .turbo *.tsbuildinfo reports .vitest-attachments 2>/dev/null || true)",
    "clean:deep": "pnpm run clean && (rm -rf node_modules 2>/dev/null || true)"
  },
  "dependencies": {
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@rtc/boot-splash": "workspace:*",
    "@rtc/client-core": "workspace:*",
    "@rtc/devtools-core": "workspace:*",
    "@rtc/domain": "workspace:*",
    "@rtc/motion-core": "workspace:*",
    "@rtc/solid-bindings": "workspace:*",
    "rxjs": "^7.8",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rtc/devtools-app": "workspace:*",
    "@rtc/ui-contract": "workspace:*",
    "@rx-state/core": "^0.1.4",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^26.0.0",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29",
    "playwright": "^1.60.0",
    "solid-devtools": "^0.34.5",
    "tsx": "^4",
    "vite": "^8",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4"
  }
}
