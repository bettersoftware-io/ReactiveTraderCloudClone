{
  "name": "@rtc/solid-bindings",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "tsc --build && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo reports 2>/dev/null || true",
    "clean:deep": "pnpm run clean && (rm -rf node_modules 2>/dev/null || true)"
  },
  "dependencies": {
    "@rtc/client-core": "workspace:*",
    "@rtc/domain": "workspace:*",
    "@rx-state/core": "^0.1.4",
    "rxjs": "^7.8",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29",
    "tsc-alias": "1.9.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4"
  }
}
