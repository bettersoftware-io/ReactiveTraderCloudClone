{
  "name": "@rtc/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./__fixtures__/wireFrames": {
      "types": "./dist/__fixtures__/wireFrames.d.ts",
      "import": "./dist/__fixtures__/wireFrames.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo reports",
    "clean:deep": "pnpm run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@rtc/domain": "workspace:*"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.8",
    "vitest": "^4"
  }
}
