{
  "name": "@rtc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "clean:deep": "pnpm run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@marblejs/core": "^4",
    "@marblejs/http": "^4",
    "@marblejs/websockets": "^4",
    "@rtc/domain": "workspace:*",
    "@rtc/shared": "workspace:*",
    "fp-ts": "^2.16",
    "rxjs": "^7.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4",
    "vitest": "^4"
  }
}
