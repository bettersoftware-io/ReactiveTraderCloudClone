{
  "name": "@rtc/client-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "imports": {
    "#/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json --noCheck && tsc-alias -p tsconfig.types.json",
    "build-types": "tsc -p tsconfig.types.json --noCheck",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.ui-visual.json && tsc --noEmit -p tsconfig.ui-contract.json",
    "test": "vitest run",
    "test:app": "vitest run src/app --outputFile.html=reports/app/report/index.html",
    "test:app:coverage": "vitest run src/app -c vitest.app.coverage.config.ts --coverage",
    "test:coverage": "pnpm test:app:coverage",
    "test:ui:coverage": "pnpm test:ui:contract:coverage && pnpm test:ui:visual:vitest-browser:react:coverage",
    "test:ui:contract": "vitest run -c tests/ui/contract/vitest.config.ts",
    "test:ui:contract:coverage": "vitest run -c tests/ui/contract/vitest.coverage.config.ts --coverage",
    "test:ui:visual": "tsx tests/ui/visual/run-all.ts",
    "test:ui:visual:react": "tsx tests/ui/visual/run-all.ts react",
    "test:ui:visual:playwright-ct:react": "playwright test -c tests/ui/visual/playwright-ct/playwright-ct.config.ts",
    "test:ui:visual:playwright-ct:react:update": "playwright test -c tests/ui/visual/playwright-ct/playwright-ct.config.ts --update-snapshots",
    "test:ui:visual:playwright-ct:react:ui": "playwright test -c tests/ui/visual/playwright-ct/playwright-ct.config.ts --ui",
    "test:ui:visual:playwright:react": "playwright test -c tests/ui/visual/playwright/playwright.config.ts",
    "test:ui:visual:playwright:react:update": "playwright test -c tests/ui/visual/playwright/playwright.config.ts --update-snapshots",
    "test:ui:visual:playwright:react:ui": "playwright test -c tests/ui/visual/playwright/playwright.config.ts --ui",
    "test:ui:visual:vitest-browser:react": "vitest run -c tests/ui/visual/vitest-browser/vitest-browser.config.ts",
    "test:ui:visual:vitest-browser:react:update": "vitest run -c tests/ui/visual/vitest-browser/vitest-browser.config.ts --update",
    "test:ui:visual:vitest-browser:react:coverage": "vitest run -c tests/ui/visual/vitest-browser/vitest-browser.coverage.config.ts --coverage",
    "dev": "vite",
    "clean": "(rm -rf dist .turbo *.tsbuildinfo reports .vitest-attachments tests/ui/visual/playwright-ct/host/.cache 2>/dev/null || true) && find tests/ui/visual -type f -path '*/__screenshots__/*' \\( -name '*-actual.png' -o -name '*-diff.png' \\) -delete",
    "clean:deep": "pnpm run clean && (rm -rf node_modules 2>/dev/null || true)"
  },
  "dependencies": {
    "@react-rxjs/core": "^0.10.7",
    "@rtc/domain": "workspace:*",
    "@rtc/shared": "workspace:*",
    "@rx-state/core": "^0.1.4",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "motion": "^12.42.0",
    "react": "^19",
    "react-dom": "^19",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@playwright/experimental-ct-react": "^1.60.0",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "^26.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29",
    "playwright": "^1.60.0",
    "tsc-alias": "1.8.17",
    "tsx": "^4",
    "vite": "^8",
    "vitest": "^4",
    "vitest-browser-react": "^2.2.0"
  }
}
