{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // "@ui-visual-shared" is unused by anything under `include` (src/ only) —
    // it's here solely so Playwright's own tsconfig-paths-based module
    // resolution (which discovers the nearest tsconfig.json by walking up
    // from each transformed file, independent of `include`) can resolve it
    // for tests/ui/visual/scenarioActions.ts and the plain-Playwright spec
    // file, which doesn't run through a Vite bundle.
    "paths": {
      "#/*": ["./src/*"],
      "@ui-visual-shared": ["../ui-contract/src/visual"],
      "@ui-visual-shared/*": ["../ui-contract/src/visual/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.golden.test.ts"],
  "references": [
    { "path": "../domain" },
    { "path": "../shared" },
    { "path": "../client-core" },
    { "path": "../react-bindings" }
  ]
}
