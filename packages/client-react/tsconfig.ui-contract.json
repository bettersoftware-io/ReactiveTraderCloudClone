{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@ui-contract": ["../ui-contract/src/shared"],
      "@ui-contract/*": ["../ui-contract/src/shared/*"],
      "#/*": ["./src/*"],
      "#tests/*": ["./tests/*"]
    }
  },
  "include": ["src", "tests/ui/contract"],
  "references": [
    { "path": "../domain" },
    { "path": "../shared" },
    { "path": "../ui-contract" }
  ]
}
