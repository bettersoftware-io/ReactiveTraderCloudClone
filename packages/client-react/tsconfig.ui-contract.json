{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@ui-contract": ["./tests/ui/contract/shared"],
      "@ui-contract/*": ["./tests/ui/contract/shared/*"],
      "#/*": ["./src/*"],
      "#tests/*": ["./tests/*"]
    }
  },
  "include": ["src", "tests/ui/contract"],
  "references": [{ "path": "../domain" }, { "path": "../shared" }]
}
