{
  "name": "@rtc/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ports/__contracts__/*": {
      "types": "./dist/ports/__contracts__/*.d.ts",
      "import": "./dist/ports/__contracts__/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "clean:deep": "pnpm run clean && rm -rf node_modules"
  },
  "dependencies": {
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "vitest": "^3"
  }
}
