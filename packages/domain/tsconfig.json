{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    // Keep the incremental cache inside dist/ so it travels with the outputs it
    // describes. In the claude-sandbox dev setup dist/ is an isolated per-env
    // volume while the package root is a shared bind mount — a root-level
    // tsbuildinfo from one environment makes `tsc --build` skip emit in the
    // other, leaving an empty dist. See docs/claude-sandbox.md.
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src"]
}
