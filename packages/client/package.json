{
  "name": "@rtc/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json --noCheck",
    "build-types": "tsc -p tsconfig.types.json --noCheck",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "test:visual:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "test:visual:ui": "playwright test -c playwright-ct.config.ts --ui",
    "dev": "vite",
    "clean": "rm -rf dist .turbo *.tsbuildinfo playwright-report test-results",
    "clean:deep": "pnpm run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@react-rxjs/core": "^0.10.7",
    "@rtc/domain": "workspace:*",
    "@rtc/shared": "workspace:*",
    "react": "^19",
    "react-dom": "^19",
    "rxjs": "^7.8"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^25",
    "vite": "^6",
    "vitest": "^3"
  }
}
