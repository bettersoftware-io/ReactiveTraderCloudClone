{
  // Type-checks the behaviour harness (tests/behaviour/) together with the
  // src files it mounts. The main tsconfig.json restricts rootDir to src, so
  // the behaviour tier — which lives outside src and imports both @rtc/domain
  // and ../../../src — needs its own no-emit program for `pnpm typecheck` to
  // catch drift between hooksFromWorld and the AppHooks interface.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    // baseUrl omitted (TS6 deprecated). Paths resolve relative to this
    // config file's directory — identical to the previous `baseUrl: "."`.
    "paths": {
      "@behaviour": ["./tests/behaviour/shared"],
      "@behaviour/*": ["./tests/behaviour/shared/*"]
    }
  },
  "include": ["src", "tests/behaviour"],
  "references": [{ "path": "../domain" }, { "path": "../shared" }]
}
