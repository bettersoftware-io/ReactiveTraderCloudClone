{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "#/*": ["./src/*"],
      "@ui-contract": ["./src/shared"],
      "@ui-contract/*": ["./src/shared/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../client-core" }, { "path": "../domain" }]
}
