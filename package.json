{
  "name": "@rtc/root",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:ui:contract": "turbo run test:ui:contract",
    "test:ui:coverage": "turbo run test:ui:coverage",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:no-cypress": "RTC_E2E_SKIP_CYPRESS=1 turbo run test:e2e",
    "test:ui:visual": "turbo run test:ui:visual",
    "test:rules": "vitest run --config eslint-rules/vitest.config.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "turbo run dev",
    "clean": "turbo run clean && (rm -rf .turbo 2>/dev/null || true)",
    "clean:deep": "turbo run clean:deep && (rm -rf node_modules .pnpm-store .turbo 2>/dev/null || true) && find . -name .DS_Store -type f -delete",
    "lint:actions": "scripts/install-actionlint.sh && .tooling/actionlint -color",
    "check:versions": "manypkg check && syncpack lint",
    "lint:dead": "knip",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages tests",
    "lint:eslint": "eslint .",
    "lint:eslint:types": "eslint . --config eslint.config.typed.mjs",
    "lint:css": "stylelint \"packages/*/src/**/*.css\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@manypkg/cli": "^0.25.1",
    "@vercel/edge": "^1.3.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "knip": "^6.17.1",
    "stylelint": "^17.13.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "syncpack": "^15.3.2",
    "turbo": "^2.4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4"
  }
}
