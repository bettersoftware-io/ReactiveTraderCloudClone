{
  "name": "@rtc/root",
  "private": true,
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:ui:contract": "turbo run test:ui:contract",
    "test:ui:coverage": "turbo run test:ui:coverage",
    "test:e2e": "turbo run test:e2e",
    "test:ui:visual": "turbo run test:ui:visual",
    "goldens:regen": "node scripts/goldens-in-container.mjs regen",
    "goldens:verify": "node scripts/goldens-in-container.mjs verify",
    "test:rules": "vitest run --config eslint-rules/vitest.config.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "pnpm run dev:react",
    "dev:ws": "AUTH_USERS=astark:mcdc2026,nromanoff:mcdc2026,tchalla:mcdc2026,demo:mcdc2026 AUTH_SECRET=dev-local-secret pnpm --filter @rtc/server dev",
    "dev:watch": "turbo run dev --filter=@rtc/client-react^... --filter=@rtc/client-solid^... --filter=@rtc/server^... --filter=!@rtc/devtools-app",
    "dev:react": "pnpm --filter @rtc/client-react dev",
    "dev:react:ws": "VITE_SERVER_URL=ws://localhost:4000 pnpm --filter @rtc/client-react dev",
    "dev:react:fs": "VITE_SERVER_URL=ws://localhost:4000 AUTH_USERS=astark:mcdc2026,nromanoff:mcdc2026,tchalla:mcdc2026,demo:mcdc2026 AUTH_SECRET=dev-local-secret turbo run dev --filter=@rtc/server --filter=@rtc/client-react",
    "dev:solid": "pnpm --filter @rtc/client-solid dev",
    "dev:solid:ws": "VITE_SERVER_URL=ws://localhost:4000 pnpm --filter @rtc/client-solid dev",
    "dev:solid:fs": "VITE_SERVER_URL=ws://localhost:4000 AUTH_USERS=astark:mcdc2026,nromanoff:mcdc2026,tchalla:mcdc2026,demo:mcdc2026 AUTH_SECRET=dev-local-secret turbo run dev --filter=@rtc/server --filter=@rtc/client-solid",
    "dev:proto": "pnpm --filter @rtc/client-prototype dev",
    "dev:design:web": "node scripts/serve-design.mjs",
    "dev:design:mobile": "node scripts/serve-design.mjs \"docs/design/mobile/v1/standalone/Reactive Trader Mobile.html\"",
    "dev:ios": "pnpm --filter @rtc/client-react-native ios",
    "dev:devtools": "pnpm --filter @rtc/devtools-app dev",
    "dev:devtools:ext": "pnpm --filter @rtc/devtools-extension dev",
    "dev:devtools:relay": "pnpm --filter @rtc/devtools-relay dev",
    "clean": "turbo run clean && (rm -rf .turbo 2>/dev/null || true)",
    "clean:deep": "turbo run clean:deep && (rm -rf node_modules .pnpm-store .turbo 2>/dev/null || true) && find . -name .DS_Store -type f -delete",
    "lint:actions": "scripts/install-actionlint.sh && .tooling/actionlint -color",
    "check:versions": "manypkg check && syncpack lint",
    "check:scripts": "node scripts/check-workspace-scripts.mjs",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:manifest-drift": "node scripts/check-manifest-drift.mjs",
    "check:image-tag-drift": "node scripts/check-image-tag-drift.mjs",
    "check:lint-warnings-drift": "node scripts/check-lint-warnings-drift.mjs",
    "sync:lint-warnings": "node scripts/sync-lint-warnings.mjs",
    "check:devtools-dist": "node scripts/check-devtools-dist.mjs",
    "lint:dead": "knip",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages tests",
    "lint:eslint": "eslint .",
    "lint:eslint:types": "eslint . --config eslint.config.typed.mjs",
    "lint:css": "stylelint \"packages/*/src/**/*.css\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@manypkg/cli": "^0.25.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "github-slugger": "^2.0.0",
    "knip": "^6.17.1",
    "stylelint": "^17.13.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "syncpack": "^15.3.2",
    "turbo": "^2.4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4"
  }
}
