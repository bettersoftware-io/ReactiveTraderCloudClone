{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "PORT",
    "HOSTNAME",
    "SITE_PASSWORD",
    "WS_ACCESS_TOKEN",
    "RTC_DEV_PORT",
    "RTC_VISUAL_MAX_PARALLEL",
    "PWCUCUMBER_HEADED",
    "FULLSTACK_PORT",
    "FULLSTACK_CLIENT_PORT",
    "FULLSTACK_HEADED",
    "GITHUB_SHA",
    "GITHUB_REF_NAME",
    "GITHUB_STEP_SUMMARY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_SERVER_URL", "VITE_WS_TOKEN"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["reports/**"]
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:ui:contract": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:ui:coverage": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_BROWSERS_PATH"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "RTC_E2E_MAX_PARALLEL",
        "RTC_E2E_SKIP_CYPRESS",
        "PLAYWRIGHT_BROWSERS_PATH"
      ]
    },
    "test:ui:visual": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_BROWSERS_PATH"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "clean:deep": {
      "cache": false
    }
  }
}
